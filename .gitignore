# ============================
# 操作系统 / 编辑器临时文件
# ============================
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.vscode/
.idea/

# ============================
# 备份文件（如盈云白.png.bak 等）
# ============================
*.bak
*.bak-*
*.orig

# ============================
# Python 测试服务器
# ============================
__pycache__/
*.pyc

# ============================
# Node / npm（如果以后加）
# ============================
node_modules/
package-lock.json

# ============================
# 日志
# ============================
*.log

# ============================
# 临时文件
# ============================
*.tmp
*.temp

# ============================
# 敏感信息（如果有 .env 文件）
# ============================
.env
.env.local

# ============================
# 媒体文件：视频、原始素材
# Cloudflare Pages 单文件上限 25 MiB
# 视频统一走外部托管（B站/视频号/YouTube）
# ============================
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.flv
*.wmv
